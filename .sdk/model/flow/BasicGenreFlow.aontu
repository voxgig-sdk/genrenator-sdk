# BasicGenreFlow

main: kit: flow: BasicGenreFlow:
{
  entity: "genre",
  kind: "basic",
  name: "BasicGenreFlow",
  step: [
    {
      input: {
        ref: "genre_ref01",
        srcdatavar: "genre_ref01_data",
        suffix: "_dt0"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-genre_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicGenreFlow"
}